{
  "name": "replication-lab (R + Quarto)",
  "image": "ghcr.io/rocker-org/devcontainer/r-ver:4",
  "features": {
    "ghcr.io/rocker-org/devcontainer-features/quarto-cli:1": {
      "version": "1.9.36"
    }
  },
  "postCreateCommand": "Rscript -e \"install.packages(c('dplyr','readr','ggplot2','broom','fixest','plm','dagitty','ggdag','modelsummary','osfr'), repos='https://packagemanager.posit.co/cran/__linux__/jammy/latest')\"",
  "customizations": {
    "vscode": {
      "extensions": [
        "quarto.quarto",
        "REditorSupport.r"
      ]
    }
  }
}
